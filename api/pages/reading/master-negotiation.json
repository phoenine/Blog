lose previous card first, then open target card for smoother switch.\n        flipSwitchTimer = setTimeout(() => {\n          card.classList.add('is-flipped')\n          flipSwitchTimer = null\n        }, 120)\n      } else {\n        card.classList.add('is-flipped')\n      }\n    }\n  })\n})()\n</script>\n"},"api":"api/pages/reading/master-negotiation.json"}